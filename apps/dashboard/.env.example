# Arcane dashboard (M1D) — copy to .env.local. The browser talks ONLY to Supabase (Realtime + an
# RLS-gated read of result_events); it never talks to the engine, and it gets ONLY the anon key.
# service_role NEVER goes here — it would defeat RLS and leak every project's data.
NEXT_PUBLIC_SUPABASE_URL=https://zbtrfghkkeuhybznwhza.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon / publishable key — Supabase → Settings → API; NOT service_role>
